VAR:
	locked: boolean;
	alive: boolean;
	trapped: boolean;
	inventory: {empty, key, disarmer, treasure};
	action: {idle, pick_up, use_item};
	hp: 0..3;
	gamestate: {running, solved, lost};
	
ASSIGN
	init(gamestate) := running;
	init(hp) := 3;
	init(locked) := TRUE;
	init(trapped) := TRUE;
	init(inventory) := empty;
	init(alive) := TRUE;

	next(gamestate) :=
		case
			hp = 0 : lost;
			inventory = treasure : solved;
			TRUE : gamestate;
		esac;

	next(hp) :=
		case
			hp > 0 & !alive : hp - 1 
			TRUE : hp
		esac;

	next(alive) :=
		case
			trapped & !locked: FALSE;
			TRUE : TRUE;
		esac;

	next(locked) :=
		case
			inventory = key & locked & action = use_item : FALSE;
			inventory = key & !locked & action = use_item : TRUE;
			TRUE: locked;
		esac;

	next(trapped) :=
		case
			inventory = disarmer & trapped & action = use_item : FALSE;
			TRUE: trapped;
		esac;

	next(inventory) :=
		case
			!locked & alive & action = pick_up: {empty, key, disarmer, treasure};
			!alive : empty;
			TRUE : {empty,key,disarmer};
		esac;

	next(action) :=
		case
			!alive : idle;
			TRUE : {idle, pick_up, use_item};
		esac;
		
		 
			

	

	
