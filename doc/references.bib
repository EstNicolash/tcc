@incollection{husungOxiDDSafeConcurrent2024,
  title = {{{OxiDD}}: {{A Safe}}, {{Concurrent}}, {{Modular}}, and {{Performant Decision Diagram Framework}} in {{Rust}}},
  shorttitle = {{{OxiDD}}},
  booktitle = {Tools and {{Algorithms}} for the {{Construction}} and {{Analysis}} of {{Systems}}},
  author = {Husung, Nils and Dubslaff, Clemens and Hermanns, Holger and K{\"o}hl, Maximilian A.},
  editor = {Finkbeiner, Bernd and Kov{\'a}cs, Laura},
  year = 2024,
  volume = {14572},
  pages = {255--275},
  publisher = {Springer Nature Switzerland},
  address = {Cham},
  doi = {10.1007/978-3-031-57256-2_13},
  urldate = {2026-05-01},
  abstract = {Abstract                            Decision diagrams               (DDs) are an important data structure in computer science with applications ranging from circuit design and verification to machine learning. Most prominently,               binary DDs               are commonly used to succinctly represent Boolean functions. Due to the practical importance of DDs, there is an ongoing quest for high-performance software libraries supporting the construction and manipulation of DDs. With OxiDD, we present a new framework for DDs that focuses on               safety               ,               concurrency               , and               modularity               . Following a highly               modular design               we implement OxiDD in Rust, which facilitates the integration of various kinds of DDs such as MTBDDs, ZBDDs, and TDDs, all within safe code also in a concurrent setting. Already in its initial release, OxiDD does not compromise               performance               , which we show to be on par with or even better than established highly optimized DD libraries.},
  isbn = {978-3-031-57255-5 978-3-031-57256-2},
  langid = {english},
  file = {/home/nan/Zotero/storage/43SMBPID/Husung et al. - 2024 - OxiDD A Safe, Concurrent, Modular, and Performant Decision Diagram Framework in Rust.pdf}
}

